# Environment Configuration Example
# Copy this file to .env and update with your actual values

# Database Configuration
DB_SERVER=localhost
DB_USER=jeraldpangan
DB_PASSWORD=balmondiyotmiya
DB_NAME=db_student_service
DB_CHARSET=utf8mb4

# Encryption Configuration
# Generate a new 256-bit (32-byte) key for production
# Use: php -r "echo bin2hex(openssl_random_pseudo_bytes(32));"
ENCRYPTION_KEY=a4f8d3c9b2e5f1a7c8d4e9f2a3b5c7d8a1f3e5c7b9d2f4a6c8e1f3a5b7d9

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# Application Configuration
APP_NAME=Student Course Enrollment System
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost/ulo-backend

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration (for future use)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_password

# Security
HASH_ALGORITHM=bcrypt
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
